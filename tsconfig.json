{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["chrome", "vite/client", "svelte"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/sidepanel/components/*"]
    }
  },
  "include": ["src", "src/**/*.svelte", "manifest.config.ts", "vite.config.ts", "eslint.config.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/sidepanel/components/ui/**/*.ts"]
}
